    "import sqlite3\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import mne\n",
    "from mne.preprocessing import ICA\n",
    "from io import BytesIO\n",
    "import matplotlib.pyplot as plt"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "8aaf3696-61a8-42fe-9e1b-a71eba4622ea",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
