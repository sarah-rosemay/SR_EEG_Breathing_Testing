    "#Load raw EEG data from SQLite database\n",
    "#Extract 4 channels (Fp1, Fp2, O1, O2) from binary chunks\n",
    "#Create MNE RawArray with proper metadata (channels, sampling rate)\n",
    "#Apply standard 1020 montage\n",
    "#Preprocess:\n",
    "#Band-pass filter (0.1–45 Hz)\n",
    "#Average reference re-referencing\n",
    "#Fit ICA (3 components)\n",
    "#Extract component sources\n",
    "#Filter into respiration band (0.1–0.4 Hz)\n",
    "#Visualize and analyze with PSD\n",
    "#Can respiration-related activity be separated as its own neural/artifact source using ICA?#\n",
    "#Attempt to isolate respiration-related components"
   ]
  },
  {
